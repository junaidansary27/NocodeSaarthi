# Contact form delivery — REPLACE CONTACT_TO_EMAIL with the business inbox before going live
CONTACT_TO_EMAIL=your-email@example.com

# SMTP delivery (optional). Leave blank to log enquiries to data/email-log.txt instead of sending.
CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=587
CONTACT_SMTP_USER=
CONTACT_SMTP_PASS=
CONTACT_SMTP_FROM=no-reply@nocodesaarthi.com
